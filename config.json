  },
  "pipeline": {
    "headless": false,
    "skip_frames": 2,
    "snapshot_interval": 5,
    "max_visitors": 10000
  },
  "dashboard": {
    "host": "0.0.0.0",
    "port": 5001,
    "debug": false,
    "auto_refresh_seconds": 10
  },
  "database": {
    "path": "database/visitors.db",
