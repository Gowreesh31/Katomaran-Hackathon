{
  "camera": {
    "source": "record_20250620_184049.mp4",
    "width": 1280,
    "height": 720,
    "fps": 30
  },
  "detection": {
    "model": "yolov8n-face.pt",
    "imgsz": 320,
    "conf_threshold": 0.45,
    "iou_threshold": 0.5,
    "tracker": "bytetrack.yaml"
  },
  "recognition": {
    "model_pack": "buffalo_l",
    "similarity_threshold": 0.6,
    "embedding_dim": 512
